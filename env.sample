# Copy this file to .env or .env.local and adjust values as needed

VITE_CARDANO_NETWORK=preprod
VITE_ADDRESS_PREFIX=addr_test1

# Koios API base
# In development mode, this defaults to '/api/koios' (Vite proxy) to avoid CORS issues
# In production, defaults to 'https://preprod.koios.rest/api/v1'
# You can override by setting VITE_KOIOS_API_BASE
# VITE_KOIOS_API_BASE=https://preprod.koios.rest/api/v1
# or for dev proxy:
# VITE_KOIOS_API_BASE=/api/koios

VITE_CARDANOSCANNER_BASE=https://preprod.cardanoscan.io
